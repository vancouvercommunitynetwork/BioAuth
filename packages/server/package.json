{
  "name": "@biometric-showcase/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "build": "echo \"No build step required for plain JavaScript\"",
    "start": "node src/index.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --coverage --passWithNoTests"
  },
  "dependencies": {
    "@simplewebauthn/server": "*",
    "better-sqlite3": "*",
    "better-sqlite3-session-store": "*",
    "cors": "*",
    "express": "*",
    "express-rate-limit": "*",
    "express-session": "*",
    "zod": "*"
  },
  "devDependencies": {
    "jest": "*",
    "supertest": "*"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
